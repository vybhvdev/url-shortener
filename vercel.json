{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)\\.(css|js|html)", "dest": "/public/$1.$2" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/([a-zA-Z0-9]{6})", "dest": "/api/index.js" }
  ]
}
